---
// Hairline-border + hover treatment borrowed from BentoCard.astro (REDESIGN §2).
// Static, zero JS. The verbatim source lives in a native <details> — on-brand
// terminal disclosure, keyboard-accessible for free.
//
// Honest & collaborative framing: when a fragment carries speaker-labelled
// spark/crystallization quotes, the disclosure shows both so the reader sees the
// raw seed and its sharpening. Legacy single-quote fragments still render.
import StatusBadge from "./StatusBadge.astro";
import { render, type CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"ideas">;
}
const { entry } = Astro.props;
const { title, date, tags, status, sources, attribution, revisits } = entry.data;
const { Content } = await render(entry);

const fmt = (d: Date) => d.toLocaleDateString("en-GB", { year: "numeric", month: "short", day: "numeric" });
const kindLabel: Record<string, string> = {
  chatgpt: "ChatGPT",
  claude: "Claude",
  codex: "Codex",
  "claude-code": "Claude Code",
  manual: "Note",
};
const speakerLabel: Record<string, string> = { you: "You", chatgpt: "ChatGPT" };

// A source may be new-style (speaker/role) or legacy (bare quote).
const labelled = sources.filter((s) => s.quote && s.speaker);
const legacy = sources.filter((s) => s.quote && !s.speaker);
const hasDisclosure = labelled.length > 0 || legacy.length > 0;
const sourceKinds = [...new Set(sources.map((s) => kindLabel[s.kind] ?? s.kind))].join(" · ");
const revisitCount = revisits?.length ?? 0;
---

<article
  id={entry.id}
  class="fragment-card mb-4 scroll-mt-20 break-inside-avoid rounded-xl border border-border bg-surface p-6 transition-colors hover:border-border-strong target:border-accent"
  data-tags={tags.join(" ")}
>
  <div class="mb-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.72rem] text-faint">
    <time datetime={date.toISOString()}>{fmt(date)}</time>
    <span aria-hidden="true">·</span>
    <StatusBadge status={status} />
    {
      revisitCount > 0 && (
        <>
          <span aria-hidden="true">·</span>
          <span title="times this idea recurs across conversations">revisited {revisitCount}×</span>
        </>
      )
    }
  </div>

  <h3 class="mb-1.5 text-[1.05rem] font-semibold tracking-[-0.01em] text-balance">{title}</h3>

  {
    attribution && (
      <p class="mb-2 font-mono text-[0.68rem] tracking-[0.02em] text-accent/90">{attribution}</p>
    )
  }

  <div class="prose-fragment text-[0.92rem] leading-relaxed text-muted">
    <Content />
  </div>

  <ul class="mt-4 flex flex-wrap gap-1.5" aria-label="Tags">
    {
      tags.map((t) => (
        <li class="rounded-full border border-border px-2.5 py-0.5 font-mono text-[0.68rem] text-faint">{t}</li>
      ))
    }
  </ul>

  {
    hasDisclosure && (
      <details class="mt-4 border-t border-border pt-3">
        <summary class="cursor-pointer font-mono text-[0.7rem] text-faint transition-colors hover:text-accent">
          source · {sourceKinds}
        </summary>
        <div class="mt-3 flex flex-col gap-3">
          {labelled.map((s) => (
            <blockquote class="border-l-2 border-accent/50 pl-3">
              <span class="font-mono text-[0.62rem] tracking-[0.08em] text-accent uppercase">
                {speakerLabel[s.speaker!] ?? s.speaker}
                {s.role ? ` · ${s.role}` : ""}
              </span>
              <p class="mt-1 font-mono text-[0.78rem] leading-relaxed text-faint">{s.quote}</p>
            </blockquote>
          ))}
          {legacy.map((s) => (
            <blockquote class="border-l-2 border-accent/50 pl-3 font-mono text-[0.78rem] leading-relaxed text-faint">
              {s.quote}
            </blockquote>
          ))}
        </div>
      </details>
    )
  }
</article>
