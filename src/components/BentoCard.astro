---
// Magic UI Bento Grid card pattern (magicui.design/docs/components/bento-grid),
// rebuilt static — no client JS. Whole card is one tab stop via a stretched link.
import type { Project } from "../config/site";

interface Props {
  project: Project;
}
const { project } = Astro.props;
---

<article
  class:list={[
    "group relative flex flex-col gap-3 rounded-xl border border-border bg-surface p-6",
    "transition-[border-color,transform] duration-200 hover:-translate-y-0.5 hover:border-border-strong",
    "motion-reduce:hover:translate-y-0",
    project.featured && "md:col-span-2 bg-gradient-to-b from-surface-2 to-surface",
  ]}
>
  <span class="font-mono text-[0.68rem] uppercase tracking-[0.08em] text-accent">{project.tag}</span>
  <h3 class="text-[1.08rem] font-semibold tracking-tight">
    <a href={project.href} class="after:absolute after:inset-0 focus-visible:outline-2 focus-visible:outline-accent">
      {project.title}
    </a>
  </h3>
  <p class="flex-1 text-sm text-muted">{project.description}</p>
  <ul class="flex flex-wrap gap-1.5" aria-label="Tech stack">
    {
      project.stack.map((s) => (
        <li class="rounded-full border border-border px-2.5 py-0.5 font-mono text-[0.68rem] text-faint">{s}</li>
      ))
    }
  </ul>
</article>
