---
import Base from "../layouts/Base.astro";
import BentoCard from "../components/BentoCard.astro";
import { projects } from "../config/site";
---

<Base title="Projects & Prototypes — abysse8" description="Detailed engineering portfolio — embedded systems, control theory, and AI automation.">
  <div class="mx-auto max-w-[1100px] px-6 pt-24">
    <header class="mb-12 max-w-[60ch]">
      <p class="font-mono text-xs tracking-[0.08em] text-accent uppercase">Room 04 — Projects &amp; Prototypes</p>
      <h1 class="mt-3 mb-4 text-[clamp(2rem,4vw,2.8rem)] font-bold tracking-[-0.025em] text-balance">
        Technical portfolio.
      </h1>
      <p class="text-[1.05rem] text-muted">
        Firmware, protocol archaeology, control theory, and AI automation — each project runs on real
        hardware or in real workflows.
      </p>
    </header>

    <div class="grid gap-4 md:grid-cols-3">
      {projects.map((project) => <BentoCard project={project} />)}
    </div>
  </div>
</Base>
