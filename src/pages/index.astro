---
import Base from "../layouts/Base.astro";
import BentoCard from "../components/BentoCard.astro";
import TransitSign from "../components/TransitSign.astro";
import NumberTicker from "../components/NumberTicker.astro";
import RecurringQuestions from "../components/RecurringQuestions.astro";
import { site, stats, projects, rooms } from "../config/site";
---

<Base title="abysse8 — Embedded Systems × Applied AI">
  <!-- Hero -->
  <div class="relative overflow-hidden pt-24 pb-16">
    <div class="grid-bg absolute inset-0 -z-10" aria-hidden="true"></div>
    <div class="mx-auto grid max-w-[1100px] items-center gap-12 px-6 min-[860px]:grid-cols-[1.1fr_0.9fr]">
      <div>
        <p class="font-mono text-xs tracking-[0.08em] text-accent uppercase">Embedded systems × applied AI</p>
        <h1 class="mt-4 mb-6 text-[clamp(2.2rem,5.2vw,3.4rem)] leading-[1.08] font-bold tracking-[-0.025em] text-balance">
          {site.headline}
        </h1>
        <p class="mb-8 max-w-[46ch] text-[1.06rem] text-muted">{site.sub}</p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/cv/"
            class="inline-flex items-center gap-2 rounded-lg bg-foreground px-4.5 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-85"
          >
            View CV →
          </a>
          <a
            href={site.github}
            class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4.5 py-2.5 text-sm font-medium transition-colors hover:border-faint hover:bg-surface"
          >
            GitHub
          </a>
        </div>
      </div>
      <TransitSign />
    </div>
  </div>

  <!-- Proof strip -->
  <div class="border-y border-border bg-surface">
    <div class="mx-auto grid max-w-[1100px] grid-cols-2 gap-y-6 px-6 py-6 min-[860px]:grid-cols-4">
      {
        stats.map((s) => (
          <div class="px-2 text-center">
            <b class="block font-mono text-[1.35rem] font-semibold tracking-tight tabular-nums">
              <NumberTicker value={s.value} prefix={s.prefix ?? ""} suffix={s.suffix ?? ""} />
            </b>
            <span class="text-[0.78rem] text-faint">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Selected work -->
  <section id="work" class="pt-24">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="reveal mb-12 max-w-[60ch]">
        <p class="font-mono text-xs tracking-[0.08em] text-accent uppercase">Selected work</p>
        <h2 class="mt-3 mb-3 text-[clamp(1.5rem,3vw,2rem)] font-semibold tracking-[-0.02em] text-balance">
          Difficult systems, shipped.
        </h2>
        <p class="text-muted">
          Firmware, protocol archaeology, control theory, and AI automation — each project runs on real hardware or in
          real workflows.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {projects.map((project) => <BentoCard project={project} />)}
      </div>
    </div>
  </section>

  <!-- Research -->
  <section id="research" class="pt-24">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="reveal mb-12 max-w-[60ch]">
        <p class="font-mono text-xs tracking-[0.08em] text-accent uppercase">Research direction</p>
        <h2 class="mt-3 text-[clamp(1.5rem,3vw,2rem)] font-semibold tracking-[-0.02em] text-balance">
          Toward a post-backpropagation learning algorithm.
        </h2>
      </div>
      <div class="reveal max-w-[62ch] border-l-2 border-accent pl-6 text-[1.02rem] text-muted">
        <p>
          My research centers on <strong class="font-medium text-foreground">excitable cells</strong> — how chemistry in
          the nucleus, transcribing and translating DNA, interacts with the electrochemistry on either side of the
          membrane. I believe we are on the brink of a
          <strong class="font-medium text-foreground">novel learning algorithm</strong> that could outperform batched
          backpropagation. Signal processing gives the first hints; group theory, wavelet analysis, and energy
          conservation belong in the unified theory of the Microscopic and the Ensemble. I want to understand both.
        </p>
        <a href="/ideas/" class="mt-6 inline-flex items-center gap-1.5 font-mono text-[0.82rem] text-accent hover:underline hover:underline-offset-4">
          → For Neuromorphs: ideas &amp; fragments
        </a>
      </div>
    </div>
  </section>

  <!-- Recurring questions timeline -->
  <RecurringQuestions />

  <!-- Exhibition rooms -->
  <section id="exhibits" class="pt-24">
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="reveal mb-12 max-w-[60ch]">
        <p class="font-mono text-xs tracking-[0.08em] text-accent uppercase">Exhibition rooms</p>
        <h2 class="mt-3 mb-3 text-[clamp(1.5rem,3vw,2rem)] font-semibold tracking-[-0.02em] text-balance">
          The museum is also a lab.
        </h2>
        <p class="text-muted">
          Everything I've built, learned, questioned, and half-dreamed — built to be explored, clicked through, and
          occasionally broken.
        </p>
      </div>
      <nav
        class="reveal grid grid-cols-1 gap-px overflow-hidden rounded-xl border border-border bg-border min-[720px]:grid-cols-3"
        aria-label="Site sections"
      >
        {
          rooms.map((room, i) => (
            <a href={room.href} class="flex flex-col gap-2 bg-bg p-6 transition-colors hover:bg-surface">
              <span class="font-mono text-[0.68rem] text-accent">{String(i + 1).padStart(2, "0")}</span>
              <b class="text-[0.92rem] font-semibold">{room.title}</b>
              <span class="text-[0.8rem] leading-normal text-faint">{room.blurb}</span>
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="pt-24">
    <div class="reveal mx-auto max-w-[1100px] px-6 text-center">
      <p class="font-mono text-xs tracking-[0.08em] text-accent uppercase">Contact</p>
      <h2 class="mt-3 mb-3 text-[clamp(1.5rem,3vw,2rem)] font-semibold tracking-[-0.02em]">
        Hiring for hard problems?
      </h2>
      <p class="mx-auto mb-8 max-w-[44ch] text-muted">
        I'm looking for roles at the intersection of embedded engineering and machine learning.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href={`mailto:${site.email}`}
          class="inline-flex items-center gap-2 rounded-lg bg-foreground px-4.5 py-2.5 text-sm font-medium text-bg transition-opacity hover:opacity-85"
        >
          {site.email}
        </a>
        <a
          href="/cv/"
          class="inline-flex items-center gap-2 rounded-lg border border-border-strong px-4.5 py-2.5 text-sm font-medium transition-colors hover:border-faint hover:bg-surface"
        >
          Digital CV
        </a>
      </div>
    </div>
  </section>
</Base>
