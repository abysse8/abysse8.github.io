        <g class="node" transform="translate(20,30)"><rect width="180" height="70" rx="10" stroke="#e8a33d"/><text x="90" y="28" class="nT" fill="#e8a33d">ALIM VÉHICULE</text><text x="90" y="50" class="nS">24 V nominal, bornier à vis</text></g>
