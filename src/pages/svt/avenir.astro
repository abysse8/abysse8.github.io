        <line x1="110" y1="220" x2="110" y2="268" stroke="#6b6b75" stroke-width="1.5" marker-end="url(#a2)"/>
        <line x1="200" y1="300" x2="280" y2="230" stroke="#6b6b75" stroke-width="1.5" marker-end="url(#a2)"/>
        <g class="node" transform="translate(285,120)"><rect width="230" height="160" rx="10" stroke="#38d6c8"/>
          <text x="115" y="34" class="nT mono" fill="#38d6c8">ESP32-WROOM-32</text>
