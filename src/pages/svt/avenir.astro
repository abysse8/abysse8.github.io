        <g class="node" transform="translate(210,20)"><rect width="180" height="76" rx="10" stroke="#e8a33d"/><text x="90" y="32" class="nT" fill="#e8a33d">Routeur RUT241</text><text x="90" y="56" class="nS">LTE · forwarding HTTP</text></g>
