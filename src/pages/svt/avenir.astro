        <g class="node" transform="translate(815,290)"><rect width="170" height="80" rx="10" stroke="#e8a33d"/><text x="85" y="30" class="nT" fill="#e8a33d">BORNIER A/B/GND</text><text x="85" y="54" class="nS">bus 2 · Lumiplan / futur</text></g>
        <line x1="770" y1="80" x2="813" y2="80" stroke="#6b6b75" stroke-width="1.5" marker-end="url(#a2)"/>
        <line x1="770" y1="330" x2="813" y2="330" stroke="#6b6b75" stroke-width="1.5" marker-end="url(#a2)"/>
